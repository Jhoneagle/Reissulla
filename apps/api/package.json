{
  "name": "@reissulla/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:e2e": "tsx test/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit -p tsconfig.test.json",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "openapi:snapshot": "tsx src/openapi-snapshot.ts",
    "test": "vitest run",
    "test:graphql-snapshot": "tsx scripts/snapshot-graphql.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@reissulla/shared": "workspace:*",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.3.3",
    "ioredis": "^5.10.1",
    "mqtt": "^5.15.1",
    "nodemailer": "^8.0.7",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@reissulla/test-fixtures": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "msw": "^2.7.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
