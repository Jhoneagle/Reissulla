<?xml version="1.0" encoding="UTF-8"?>
<!--
  Canonical FMI WFS warnings response baseline.

  This is a trimmed snapshot of the shape returned by FMI's
  `fmi::warnings::regional` stored query — a wfs:FeatureCollection
  carrying one or more fmi:Warning elements. Real FMI responses are
  ~10x larger; this excerpt covers every field the parser actually
  reads (id, severity, type, region, time range, bilingual
  descriptions, gml polygon).

  If FMI ships a backwards-incompatible XML shape, the snapshot test
  in `__tests__/fixture-snapshots.test.ts` re-parses this file on
  every PR and asserts the parsed FmiWarning record matches the
  pinned expected shape — surfacing the drift as a loud CI red
  rather than a silent runtime fallback to `[]`.

  Source: derived from a real Uusimaa wind warning, sanitised. To
  refresh against the live API, run:
    curl -G 'https://opendata.fmi.fi/wfs' \
      --data-urlencode 'service=WFS' \
      --data-urlencode 'version=2.0.0' \
      --data-urlencode 'request=GetFeature' \
      --data-urlencode 'storedquery_id=fmi::warnings::regional'
-->
<wfs:FeatureCollection xmlns:wfs="http://www.opengis.net/wfs/2.0"
                       xmlns:gml="http://www.opengis.net/gml/3.2"
                       xmlns:fmi="http://xml.fmi.fi/schema/wfs/2.0">
  <wfs:member>
    <fmi:Warning gml:id="warning-uusimaa-wind-001">
      <fmi:severity>Severe</fmi:severity>
      <fmi:type>Wind</fmi:type>
      <fmi:region>FI:Uusimaa</fmi:region>
      <fmi:timeRange>
        <fmi:startTime>2026-06-06T09:00:00Z</fmi:startTime>
        <fmi:endTime>2026-06-06T18:00:00Z</fmi:endTime>
      </fmi:timeRange>
      <fmi:description lang="fi">Voimakas tuuli, puuskat jopa 25 m/s rannikolla.</fmi:description>
      <fmi:description lang="en">Strong wind, gusts up to 25 m/s along the coast.</fmi:description>
      <fmi:bounds>
        <gml:Polygon srsName="EPSG:4326">
          <gml:exterior>
            <gml:LinearRing>
              <gml:posList>60.10 24.80 60.10 25.20 60.40 25.20 60.40 24.80 60.10 24.80</gml:posList>
            </gml:LinearRing>
          </gml:exterior>
        </gml:Polygon>
      </fmi:bounds>
    </fmi:Warning>
  </wfs:member>
</wfs:FeatureCollection>
