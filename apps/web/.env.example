# reCAPTCHA v3 site key (public, paired with RECAPTCHA_SECRET_KEY on the API).
# Leave empty in dev to skip recaptcha entirely — the API will also be in
# disabled-passthrough mode and accept any token.
VITE_RECAPTCHA_SITE_KEY=

# Optional swap for the default OpenStreetMap tile template used by the map
# layer registry. Leave empty to use the bundled OSM default. Set this when
# pointing a self-hosted or paid tile provider (escape hatch from OSM's
# fair-use policy — see docs/architecture.md §5.5).
# Example: https://tiles.example.com/styles/streets/{z}/{x}/{y}.png
VITE_MAP_TILE_BASE_URL=
