# Database
DATABASE_URL=postgresql://reissulla:reissulla_dev@localhost:5432/reissulla

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# Auth (Better Auth)
AUTH_SECRET=generate-a-random-secret-here

# OAuth — Google (optional, leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External APIs
DIGITRANSIT_API_KEY=your-digitransit-api-key

# FMI Open Data — sent as User-Agent on every WFS/WMS request per FMI's
# fair-use policy. Use a contactable identifier (project name + email).
FMI_USER_AGENT=reissulla-dev <your-email@example.com>

# Fintraffic Open API base URL (optional override; defaults to public host).
FINTRAFFIC_API_BASE=

# Transit feed kill switches (set to "false" to disable a feed)
FEED_FINLAND_ENABLED=true
FEED_HSL_ENABLED=true
FEED_WALTTI_ENABLED=true
FEED_VARELY_ENABLED=true

# Realtime / SSE — master kill switch for /api/v1/.../live endpoints and the
# bus + registry behind them. On now that the closeout acceptance sweep has
# passed; set to "false" to fail the whole live pipeline closed if a broker
# or upstream regresses.
REALTIME_SSE_ENABLED=true
# Bus implementation: "memory" (single-instance default) or "redis-pubsub"
# (multi-instance via the existing Redis client).
REALTIME_BUS=memory

# Digitransit MQTT broker (vehicle positions). Leave blank in dev/test so the
# adapter never reaches the network; the line-vehicles channel then serves the
# polled `vehiclePositions` GraphQL fallback. For live HSL dots set
# MQTT_BROKER_URL=wss://mqtt.hsl.fi:443/ (public, no credentials).
MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
# How long the broker may stay unreachable before degrading to the polled
# GraphQL fallback (and raising freshness.degraded). Reconnecting clears it.
MQTT_FALLBACK_AFTER_MS=60000
# Polling cadence (ms) for the degraded GraphQL vehicle fallback.
REALTIME_VEHICLE_FALLBACK_POLL_MS=5000
# Coalesce cadence (ms) for the per-line vehicle SSE snapshot.
REALTIME_VEHICLE_PUBLISH_MS=1000
# Drop a vehicle from the live set after this long without a ping (ms).
REALTIME_VEHICLE_STALE_MS=90000

# Per-stop live-departures poll cadence (ms). 5 s gives an upper-bound
# latency budget for the "ETA updates ≤ 5 s after upstream change" gate.
REALTIME_STOP_POLL_MS=5000

# Shared poller cadence for the alerts.service stream (Chunk 4 consumer).
ALERTS_POLL_INTERVAL_SEC=60
# Default trip-log retention window for the nightly prune cron (Chunk 7).
HISTORY_RETENTION_DAYS_DEFAULT=90

# Rate-limit budget per IP per minute (the /api/v1/health route is exempt)
RATE_LIMIT_MAX=200

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Base URL (required in production for auth callbacks)
BASE_URL=http://localhost:3000

# Email transport for magic-link sign-in and other transactional messages.
# - "smtp": production (uses SMTP_* below); the documented free option is
#   Brevo (300 emails/day, no card required).
# - "console": dev (logs messages instead of sending; copy magic-link URLs
#   out of the API log).
# - "null": test (silently records sends; never delivers).
# Leave unset to auto-pick: console in dev, smtp in production, null in test.
EMAIL_TRANSPORT=
EMAIL_FROM=Reissulla <no-reply@reissulla.fi>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# reCAPTCHA v3 (invisible, score-based) for login / register / magic-link.
# Leave both keys empty in dev to bypass verification (every request scores 1.0).
# In production, set the v3 site + secret keys from your Google Cloud project.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Score floor (0..1). Below this, the auth flow routes through magic-link
# instead of the password path — never via a challenge UI.
RECAPTCHA_THRESHOLD=0.5
