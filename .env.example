# Database
DATABASE_URL=postgresql://reissulla:reissulla_dev@localhost:5432/reissulla

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3000
NODE_ENV=development

# Auth (Better Auth)
AUTH_SECRET=generate-a-random-secret-here

# OAuth — Google (optional, leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# External APIs
DIGITRANSIT_API_KEY=your-digitransit-api-key

# Transit feed kill switches (set to "false" to disable a feed)
FEED_FINLAND_ENABLED=true
FEED_HSL_ENABLED=true

# Rate-limit budget per IP per minute (the /api/v1/health route is exempt)
RATE_LIMIT_MAX=200

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Base URL (required in production for auth callbacks)
BASE_URL=http://localhost:3000

# Email transport for magic-link sign-in and other transactional messages.
# - "smtp": production (uses SMTP_* below); the documented free option is
#   Brevo (300 emails/day, no card required).
# - "console": dev (logs messages instead of sending; copy magic-link URLs
#   out of the API log).
# - "null": test (silently records sends; never delivers).
# Leave unset to auto-pick: console in dev, smtp in production, null in test.
EMAIL_TRANSPORT=
EMAIL_FROM=Reissulla <no-reply@reissulla.fi>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# reCAPTCHA v3 (invisible, score-based) for login / register / magic-link.
# Leave both keys empty in dev to bypass verification (every request scores 1.0).
# In production, set the v3 site + secret keys from your Google Cloud project.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# Score floor (0..1). Below this, the auth flow routes through magic-link
# instead of the password path — never via a challenge UI.
RECAPTCHA_THRESHOLD=0.5
